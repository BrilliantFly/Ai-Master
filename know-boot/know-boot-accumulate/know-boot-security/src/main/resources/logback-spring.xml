<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/base.xml"/>

    <springProperty scope="context" name="springAppName" source="spring.application.name" defaultValue="know"/>

    <!-- springboot配置 -->
    <springProperty scope="context" name="path" source="logging.logback-spring.path"/>
    <springProperty scope="context" name="filename" source="logging.logback-spring.filename"/>
    <springProperty scope="context" name="maxHistory" source="logging.logback-spring.max-history"/>

    <!-- springcloud配置，但是文件在当前目录生成，不会到指定位置 -->
<!--    <property name="filename" value="${springAppName}" />-->
